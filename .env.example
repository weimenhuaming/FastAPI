# 智谱大模型 API Key（必填）
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_MODEL=glm-4-plus

# 知识库文档目录
DOCS_DIR=data/docs

# Chroma 向量库持久化目录
CHROMA_PERSIST_DIR=data/chroma_db

# 本地嵌入模型（首次会下载）
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# 文本切分
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_K=4
